# GitHub Pages (use /portfolio para username.github.io/portfolio)
NEXT_PUBLIC_BASE_PATH=/portfolio

# Formspree: create a form at https://formspree.io and paste your form id below.
# The form will send name, email, and message to your Formspree inbox.
# Copy this file to .env.local and fill in your values. Never commit .env.local.
NEXT_PUBLIC_FORMSPREE_FORM_ID=your_form_id_here
