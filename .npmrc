# ============================================
# pnpm - Configuração otimizada para performance e compatibilidade
# ============================================

# --- Compatibilidade (evita erros de resolução de módulos) ---
# Next.js, ESLint e outras ferramentas esperam deps no root de node_modules
shamefully-hoist=true

# --- Performance ---
# Priorizar cache local
prefer-offline=true

# Conexões paralelas para downloads (default: 16)
network-concurrency=32

# Pular audit durante install
audit=false

# Pular mensagens de funding
fund=false

# Retries e timeout (evita ETIMEDOUT em conexões lentas)
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=120000

# Log enxuto
loglevel=warn

# --- Registry (npmmirror - CDN global, mais estável que registry.npmjs.org) ---
registry=https://registry.npmmirror.com/

# --- Reproduzibilidade ---
save-exact=true

# --- Store (evita EACCES em ambientes restritos) ---
# Store no projeto = sem permissões em ~/.local/share
# Descomente se tiver problemas de permissão:
# store-dir=.pnpm-store
